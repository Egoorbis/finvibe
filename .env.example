# Application Environment
NODE_ENV=production

# Server Configuration
BACKEND_PORT=3000
FRONTEND_PORT=80

# Database Configuration
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=finvibe
DB_USER=finvibe_user
DB_PASSWORD=change_me_strong_password

# Authentication Configuration
# REQUIRED: Generate a secure random string for JWT signing
# Run: openssl rand -base64 64
JWT_SECRET=replace_with_output_of_openssl_rand_-base64_64

# Email Configuration (optional - enables password reset and verification emails)
# Sign up at https://resend.com to get an API key
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# CORS Configuration
CORS_ORIGIN=http://localhost
