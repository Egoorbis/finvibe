# Application Environment
NODE_ENV=production

# Server Configuration
BACKEND_PORT=3000
FRONTEND_PORT=80

# Database Configuration
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=finvibe
DB_USER=finvibe_user
DB_PASSWORD=finvibe_password

# Authentication Configuration
# REQUIRED: Generate a secure random string for JWT signing
# Example: openssl rand -base64 64
# IMPORTANT: This variable is required for security. The application will not start without it.
JWT_SECRET=your_secure_jwt_secret_here_min_32_characters

# CORS Configuration
CORS_ORIGIN=http://localhost
