# Database Configuration
# Options: 'sqlite' (development/testing) or 'postgres' (production)
DB_TYPE=sqlite

# PostgreSQL Configuration (only needed if DB_TYPE=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finvibe
DB_USER=finvibe_user
DB_PASSWORD=your_secure_password_here

# Authentication Configuration
# Generate a secure random string for JWT signing
# Example: openssl rand -base64 64
JWT_SECRET=your_secure_jwt_secret_here_min_32_characters

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# Email Configuration (SMTP)
# For SendGrid: use smtp.sendgrid.net, port 587, user=apikey, password=your_api_key
# For Gmail: use smtp.gmail.com, port 587, user=your_email, password=app_password
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key_here
SMTP_FROM="FinVibe <noreply@finvibe.com>"

# Application URL (for email links)
FRONTEND_URL=http://localhost:5173

# Azure Application Insights (optional - for production monitoring)
# Get from: Azure Portal > Application Insights > Properties > Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key-here;IngestionEndpoint=https://...
APPINSIGHTS_SAMPLING_RATIO=1.0

