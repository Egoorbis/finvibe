# Secret templates — copy to db-secret.yaml and fill in real values before applying.
# NEVER commit real secret values to source control.
# Consider using Sealed Secrets, External Secrets Operator, or Talos machine secrets instead.
#
# Apply with: kubectl apply -f k8s/secrets/db-secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: db-secret
  namespace: finvibe
type: Opaque
stringData:
  POSTGRES_DB: finvibe
  POSTGRES_USER: finvibe_user
  # CHANGE THIS — use a strong random password
  POSTGRES_PASSWORD: CHANGE_ME_STRONG_PASSWORD
