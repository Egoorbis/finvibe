# Secret template — copy to app-secret.yaml and fill in real values before applying.
# NEVER commit real secret values to source control.
# Consider using Sealed Secrets, External Secrets Operator, or Talos machine secrets instead.
#
# Apply with: kubectl apply -f k8s/secrets/app-secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: app-secret
  namespace: finvibe
type: Opaque
stringData:
  # CHANGE THIS — generate with: openssl rand -hex 64
  JWT_SECRET: CHANGE_ME_JWT_SECRET_MIN_32_CHARS
  # Optional: Resend API key for email functionality
  RESEND_API_KEY: ""
